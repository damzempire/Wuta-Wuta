# Muse Marketplace - Soroban & AI
# -----------------------------

# AI Art Generation (Choose one or both)
# Required for generating NFTs from prompts
OPENAI_API_KEY=your_openai_api_key_here
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Stellar Network Configuration (Default: Futurenet)
# No API key needed for basic RPC, but mandatory for mainnet providers like BlockDaemon
REACT_APP_RPC_URL=https://rpc-futurenet.stellar.org
REACT_APP_HORIZON_URL=https://horizon-testnet.stellar.org
REACT_APP_NETWORK_PASSPHRASE="Test SDF Future Network ; October 2022"

# Soroban Smart Contract IDs
# These are deployed on Futurenet/Testnet
REACT_APP_ART_ASSET_TOKEN_CONTRACT=CDA... (Your ArtAsset SAC Id)
REACT_APP_NFT_MARKETPLACE_CONTRACT=CBA... (Your Marketplace Id)

# Optional: Private key for development (NEVER commit actual keys)
# Use Freight wallet for secure production use
USER_SECRET_KEY=S... (Stellar Secret Key)

# Server Configuration
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
JWT_SECRET=your_jwt_secret_here
